<Application x:Class="drinkOrderSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/DrinkOrderWindow.xaml">

    <Application.Resources>

        <!-- ========================================
             カラー定義
        ======================================== -->
        <SolidColorBrush x:Key="HeaderBrush"              Color="#FF404040"/>
        <SolidColorBrush x:Key="ContentBackgroundBrush"   Color="#FFF5EDDC"/>
        <SolidColorBrush x:Key="NavButtonSettingBrush"    Color="#FF4FB3E8"/>
        <SolidColorBrush x:Key="NavButtonTableBrush"      Color="#FFED9A2E"/>
        <SolidColorBrush x:Key="NavButtonAttendanceBrush" Color="#FF5CB85C"/>
        <SolidColorBrush x:Key="SideButtonBrush"          Color="#FFE8884A"/>
        <SolidColorBrush x:Key="SideButtonHoverBrush"     Color="#FFFF9A5A"/>
        <SolidColorBrush x:Key="TableEmptyBrush"          Color="#FF6FA8DC"/>
        <SolidColorBrush x:Key="TableEmptyHoverBrush"     Color="#FF85BFEC"/>
        <SolidColorBrush x:Key="TableUsedBrush"           Color="#FFFFC000"/>
        <SolidColorBrush x:Key="TableUsedHoverBrush"      Color="#FFFFD040"/>
        <SolidColorBrush x:Key="AttendStartBrush"         Color="#FF5CB85C"/>
        <SolidColorBrush x:Key="AttendStartHoverBrush"    Color="#FF6FCF6F"/>
        <SolidColorBrush x:Key="AttendEndBrush"           Color="#FFED9A2E"/>
        <SolidColorBrush x:Key="AttendEndHoverBrush"      Color="#FFFFB040"/>
        <SolidColorBrush x:Key="RevertButtonBrush"        Color="#FFE88080"/>
        <SolidColorBrush x:Key="RevertButtonHoverBrush"   Color="#FFFF9090"/>
        <SolidColorBrush x:Key="CloseButtonBrush"         Color="#FFCC3333"/>
        <SolidColorBrush x:Key="CloseButtonHoverBrush"    Color="#FFEE4444"/>

        <!-- スケール未適用時のフォールバック値（App.xaml.csで上書きされる） -->
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeSm">12</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeMd">14</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeLg">16</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeXl">18</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeHeader">18</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSizeNav">14</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="FontSideBtn">15</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="BtnSizeNav">60</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="BtnSizeSide">80</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="BtnSideMargin">20</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="HeaderHeight">60</sys:Double>
        <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    x:Key="RowHeight">34</sys:Double>

        <!-- ========================================
             ヘッダー背景ブラシ（菱形パターン）
        ======================================== -->
        <DrawingBrush x:Key="HeaderPatternBrush"
                      TileMode="Tile"
                      Viewport="0,0,12,12"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF3A3A3A">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,12,12"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF4A4A4A">
                        <GeometryDrawing.Geometry>
                            <PathGeometry Figures="M6,0 L12,6 L6,12 L0,6 Z"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- ========================================
             背景テクスチャブラシ（ベージュ斑点）
        ======================================== -->
        <DrawingBrush x:Key="ContentTextureBrush"
                      TileMode="Tile"
                      Viewport="0,0,40,40"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFF5EDDC">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,40,40"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#10C8A060">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="10,8" RadiusX="5" RadiusY="3"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#0EC8A060">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="28,22" RadiusX="4" RadiusY="4"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#08C8A060">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="18,32" RadiusX="6" RadiusY="2"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- ========================================
             ナビゲーションボタン（丸形・スケール対応）
        ======================================== -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="{DynamicResource BtnSizeNav}"/>
            <Setter Property="Height"          Value="{DynamicResource BtnSizeNav}"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeNav}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             ×閉じるボタン（丸形・ヘッダー右端）
        ======================================== -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="{DynamicResource BtnSizeNav}"/>
            <Setter Property="Height"          Value="{DynamicResource BtnSizeNav}"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeNav}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource CloseButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource CloseButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             サイドメニューボタン（角丸・スケール対応）
        ======================================== -->
        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="{DynamicResource BtnSizeSide}"/>
            <Setter Property="Height"          Value="{DynamicResource BtnSizeSide}"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSideBtn}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#FF3A2000"/>
            <Setter Property="Background"      Value="{StaticResource SideButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,0,20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SideButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             テーブルボタン（空席：青）
        ======================================== -->
        <Style x:Key="TableEmptyButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="120"/>
            <Setter Property="Height"          Value="120"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeXl}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource TableEmptyBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TableEmptyHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             テーブルボタン（使用中：黄）
        ======================================== -->
        <Style x:Key="TableUsedButtonStyle" TargetType="Button">
            <Setter Property="MinWidth"        Value="120"/>
            <Setter Property="MinHeight"       Value="120"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeMd}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="#FF3A2000"/>
            <Setter Property="Background"      Value="{StaticResource TableUsedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TableUsedHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             出勤ボタン（緑・角丸）
        ======================================== -->
        <Style x:Key="AttendStartButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="68"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeMd}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource AttendStartBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AttendStartHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             退勤ボタン（オレンジ・角丸）
        ======================================== -->
        <Style x:Key="AttendEndButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="68"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeMd}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource AttendEndBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AttendEndHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             戻すボタン（ピンク・丸形）
        ======================================== -->
        <Style x:Key="RevertButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="48"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="FontSize"        Value="{DynamicResource FontSizeSm}"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource RevertButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource RevertButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================
             勤怠行ボーダー
        ======================================== -->
        <Style x:Key="AttendanceRowStyle" TargetType="Border">
            <Setter Property="Background"      Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius"    Value="20"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Application.Resources>

</Application>
