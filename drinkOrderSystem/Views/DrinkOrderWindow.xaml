<Window x:Class="drinkOrderSystem.Views.DrinkOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPosSystem - ドリンカーシステム"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize">

    <!-- 設計書image4: DataGridが上部大半・下部にベージュ余白＋右下に反映ボタン -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.RowDefinitions>
            <!-- DataGrid（設計書の上部約65%） -->
            <RowDefinition Height="3*"/>
            <!-- 下部余白＋反映ボタンエリア（設計書の下部約35%） -->
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             オーダーDataGrid
             設計書: 上部に白枠DataGrid・外側にベージュ余白12px
        ═══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Margin="12,12,12,6"
                BorderBrush="#FFCCCCCC"
                BorderThickness="1"
                Background="White">

            <DataGrid x:Name="OrderDataGrid"
                      ItemsSource="{Binding FilteredOrders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#FFDDDDDD"
                      VerticalGridLinesBrush="#FFDDDDDD"
                      RowHeight="34"
                      FontSize="14"
                      SelectionMode="Single"
                      BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#FFFFFBE6"/>
                        <Setter Property="Foreground"      Value="#FF4B7BBE"/>
                        <Setter Property="FontWeight"      Value="Bold"/>
                        <Setter Property="FontSize"        Value="13"/>
                        <Setter Property="Height"          Value="34"/>
                        <Setter Property="BorderBrush"     Value="#FFCCCCCC"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"         Value="8,0,4,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!-- テーブル名（▼フィルタ） -->
                    <DataGridTemplateColumn Width="130">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="テーブル名" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DataContext.TableNames,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedTableNameFilter,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Mode=TwoWay}"
                                          Width="26" Height="20" Margin="4,0,0,0"
                                          FontSize="10" Padding="0"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SetNumber}"
                                           Padding="8,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 商品名 -->
                    <DataGridTextColumn Header="商品名"
                                        Binding="{Binding ProductName}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 数量 -->
                    <DataGridTextColumn Header="数量"
                                        Binding="{Binding Quantity}"
                                        Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"             Value="8,0"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- キャスト名 -->
                    <DataGridTextColumn Header="キャスト名"
                                        Binding="{Binding CastName}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- ステータス（▼フィルタ） -->
                    <DataGridTemplateColumn Width="130">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ステータス" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DataContext.StatusList,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedStatusFilter,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Mode=TwoWay}"
                                          Width="26" Height="20" Margin="4,0,0,0"
                                          FontSize="10" Padding="0"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}"
                                           Padding="8,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 行ごとの▼ボタン -->
                    <DataGridTemplateColumn Width="44" Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="▼"
                                        Width="30" Height="24"
                                        FontSize="11"
                                        Margin="4,0"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{StaticResource AttendStartBrush}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background"
                                                            Value="{StaticResource AttendStartHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Opacity" Value="0.75"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- ═══════════════════════════════════════
             下部エリア（ベージュ余白）＋反映ボタン右下
             設計書: 反映ボタンは右下に配置
        ═══════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Button x:Name="ReflectButton"
                    Content="反映"
                    Width="80"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,20"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ReflectButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource AttendStartBrush}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource AttendStartHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>

</Window>
