<Window x:Class="drinkOrderSystem.Views.DrinkOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPosSystem - ドリンカーシステム"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False">

    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー：Paddingで上下余白確保 -->
        <Border Grid.Row="0"
                MinHeight="{DynamicResource HeaderHeight}"
                Padding="0,10,0,10"
                Background="{StaticResource HeaderPatternBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="ドリンカーシステム"
                           Foreground="#AAFFFFFF"
                           FontSize="{DynamicResource FontSizeHeader}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <!-- とじるボタン -->
                <Button Grid.Column="1"
                        Style="{StaticResource CloseButtonStyle}"
                        Margin="0,0,12,0"
                        Click="CloseButton_Click">
                    <TextBlock TextAlignment="Center"
                               FontSize="{DynamicResource FontSizeSm}"
                               FontWeight="Bold"
                               LineHeight="16">
                        <Run Text="とじる"/>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <!-- DataGrid：画面いっぱいに拡張 -->
        <Border Grid.Row="1"
                Margin="12,12,12,6"
                BorderBrush="#FFCCCCCC"
                BorderThickness="1"
                Background="White">

            <DataGrid x:Name="OrderDataGrid"
                      ItemsSource="{Binding FilteredOrders}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#FFDDDDDD"
                      VerticalGridLinesBrush="#FFDDDDDD"
                      RowHeight="{DynamicResource RowHeight}"
                      FontSize="{DynamicResource FontSizeMd}"
                      SelectionMode="Single"
                      BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#FFFFFBE6"/>
                        <Setter Property="Foreground"      Value="#FF4B7BBE"/>
                        <Setter Property="FontWeight"      Value="Bold"/>
                        <Setter Property="FontSize"        Value="{DynamicResource FontSizeMd}"/>
                        <Setter Property="Height"          Value="{DynamicResource RowHeight}"/>
                        <Setter Property="BorderBrush"     Value="#FFCCCCCC"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"         Value="8,0,4,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!-- テーブル名列（フィルタComboBox固定幅） -->
                    <DataGridTemplateColumn Width="180">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="テーブル名" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DataContext.TableNames,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedTableNameFilter,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Mode=TwoWay}"
                                          Width="70" Height="{DynamicResource FilterComboHeight}"
                                          Margin="6,0,0,0"
                                          FontSize="{DynamicResource FontSizeSm}"
                                          Padding="4,0"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SetNumber}"
                                           Padding="8,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 商品名列 -->
                    <DataGridTextColumn Header="商品名" Binding="{Binding ProductName}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 数量列 -->
                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"             Value="8,0"/>
                                <Setter Property="VerticalAlignment"   Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- キャスト名列 -->
                    <DataGridTextColumn Header="キャスト名" Binding="{Binding CastNamesDisplay}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- ステータス列（フィルタComboBox固定幅） -->
                    <DataGridTemplateColumn Width="180">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ステータス" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding DataContext.StatusList,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding DataContext.SelectedStatusFilter,
                                              RelativeSource={RelativeSource AncestorType=Window},
                                              Mode=TwoWay}"
                                          Width="70" Height="{DynamicResource FilterComboHeight}"
                                          Margin="6,0,0,0"
                                          FontSize="{DynamicResource FontSizeSm}"
                                          Padding="4,0"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}"
                                           Padding="8,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- フッター：反映ボタンのみ -->
        <Border Grid.Row="2"
                Background="{StaticResource ContentTextureBrush}"
                Padding="0,8,16,16">
            <Button x:Name="ReflectButton"
                    Content="反映"
                    Width="100" Height="44"
                    HorizontalAlignment="Right"
                    FontSize="{DynamicResource FontSizeLg}"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ReflectButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource AttendStartBrush}" CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AttendStartHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

    </Grid>

</Window>
