<UserControl x:Class="wpf.Views.Pages.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 設定画面：左サイドメニュー＋中央コンテンツエリア -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.ColumnDefinitions>
            <!-- サイドメニュー -->
            <ColumnDefinition Width="120"/>
            <!-- コンテンツエリア -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── サイドメニュー ─────────────────────── -->
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Top"
                    Margin="16,20,8,20">

            <Button x:Name="SideButton1"
                    Content="釦１"
                    Style="{StaticResource SideButtonStyle}"/>

            <Button x:Name="SideButton2"
                    Content="釦２"
                    Style="{StaticResource SideButtonStyle}"/>

            <Button x:Name="SideButton3"
                    Content="釦３"
                    Style="{StaticResource SideButtonStyle}"/>

        </StackPanel>

        <!-- ─── コンテンツエリア ──────────────────── -->
        <Border Grid.Column="1"
                Background="White"
                Margin="8,20,20,20"
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1"
                                  BlurRadius="4"
                                  Opacity="0.15"/>
            </Border.Effect>

            <!-- コンテンツはボタン制御実装時に追加 -->
            <ContentControl x:Name="ContentArea"/>

        </Border>

    </Grid>

</UserControl>
