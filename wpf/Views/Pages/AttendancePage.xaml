<UserControl x:Class="wpf.Views.Pages.AttendancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 勤怠画面：キャスト行ごとに 名前・出勤時間・出勤ボタン・退勤時間・退勤ボタン・前借・戻すボタン -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <ScrollViewer Margin="16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <!-- キャスト行一覧（ボタン制御実装時に動的生成） -->
            <StackPanel x:Name="AttendanceListPanel"
                        Orientation="Vertical">

                <!-- ─── キャスト行 サンプル ─── -->
                <Border Style="{StaticResource AttendanceRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- 名前 -->
                            <ColumnDefinition Width="100"/>
                            <!-- 出勤時間 -->
                            <ColumnDefinition Width="90"/>
                            <!-- 出勤ボタン -->
                            <ColumnDefinition Width="80"/>
                            <!-- 退勤時間 -->
                            <ColumnDefinition Width="90"/>
                            <!-- 退勤ボタン -->
                            <ColumnDefinition Width="80"/>
                            <!-- 区切り -->
                            <ColumnDefinition Width="24"/>
                            <!-- 前借ラベル -->
                            <ColumnDefinition Width="44"/>
                            <!-- 前借入力 -->
                            <ColumnDefinition Width="90"/>
                            <!-- 戻すボタン -->
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>

                        <!-- 名前 -->
                        <TextBlock Grid.Column="0"
                                   Text="名前１"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <!-- 出勤時間 -->
                        <TextBox Grid.Column="1"
                                 x:Name="StartTimeBox"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 IsReadOnly="True"
                                 Background="#FFF0F0F0"
                                 BorderBrush="#FFCCCCCC"/>

                        <!-- 出勤ボタン -->
                        <Button Grid.Column="2"
                                Content="出勤"
                                Style="{StaticResource AttendStartButtonStyle}"
                                Margin="4,0"/>

                        <!-- 退勤時間 -->
                        <TextBox Grid.Column="3"
                                 x:Name="EndTimeBox"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 IsReadOnly="True"
                                 Background="#FFF0F0F0"
                                 BorderBrush="#FFCCCCCC"/>

                        <!-- 退勤ボタン -->
                        <Button Grid.Column="4"
                                Content="退勤"
                                Style="{StaticResource AttendEndButtonStyle}"
                                Margin="4,0"/>

                        <!-- 前借ラベル -->
                        <TextBlock Grid.Column="6"
                                   Text="前借"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,4,0"/>

                        <!-- 前借入力 -->
                        <TextBox Grid.Column="7"
                                 x:Name="AdvancePayBox"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 BorderBrush="#FF4FB3E8"
                                 BorderThickness="2"/>

                        <!-- 戻すボタン -->
                        <Button Grid.Column="8"
                                Content="戻す"
                                Style="{StaticResource RevertButtonStyle}"
                                Margin="8,0,0,0"/>

                    </Grid>
                </Border>

                <!-- ─── キャスト行 サンプル2（表示確認用） ─── -->
                <Border Style="{StaticResource AttendanceRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="名前１"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 IsReadOnly="True"
                                 Background="#FFF0F0F0"
                                 BorderBrush="#FFCCCCCC"/>

                        <Button Grid.Column="2"
                                Content="出勤"
                                Style="{StaticResource AttendStartButtonStyle}"
                                Margin="4,0"/>

                        <TextBox Grid.Column="3"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 IsReadOnly="True"
                                 Background="#FFF0F0F0"
                                 BorderBrush="#FFCCCCCC"/>

                        <Button Grid.Column="4"
                                Content="退勤"
                                Style="{StaticResource AttendEndButtonStyle}"
                                Margin="4,0"/>

                        <TextBlock Grid.Column="6"
                                   Text="前借"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,4,0"/>

                        <TextBox Grid.Column="7"
                                 Height="36"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 Margin="4,0"
                                 BorderBrush="#FF4FB3E8"
                                 BorderThickness="2"/>

                        <Button Grid.Column="8"
                                Content="戻す"
                                Style="{StaticResource RevertButtonStyle}"
                                Margin="8,0,0,0"/>

                    </Grid>
                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>
