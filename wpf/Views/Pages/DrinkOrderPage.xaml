<UserControl x:Class="wpf.Views.Pages.DrinkOrderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ドリンカー画面：オーダーDataGrid＋反映ボタン -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.RowDefinitions>
            <!-- DataGrid -->
            <RowDefinition Height="*"/>
            <!-- 反映ボタンエリア -->
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- ─── オーダーDataGrid ──────────────────── -->
        <Border Grid.Row="0"
                Margin="16,16,16,4"
                BorderBrush="#FFCCCCCC"
                BorderThickness="1"
                Background="White">

            <DataGrid x:Name="OrderDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#FFDDDDDD"
                      VerticalGridLinesBrush="#FFDDDDDD"
                      RowHeight="36"
                      FontSize="14"
                      SelectionMode="Single"
                      BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"     Value="#FFFFFBE6"/>
                        <Setter Property="Foreground"     Value="#FF4B7BBE"/>
                        <Setter Property="FontWeight"     Value="Bold"/>
                        <Setter Property="FontSize"       Value="13"/>
                        <Setter Property="Height"         Value="36"/>
                        <Setter Property="BorderBrush"    Value="#FFCCCCCC"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="Padding"        Value="8,0,4,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <!-- テーブル名（フィルタ▼付き） -->
                    <DataGridTemplateColumn Width="110">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="テーブル名"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼"
                                           Foreground="#FF4B7BBE"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SetNumber}"
                                           Padding="8,0"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 商品名 -->
                    <DataGridTextColumn Header="商品名"
                                        Binding="{Binding ProductName}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- 数量 -->
                    <DataGridTextColumn Header="数量"
                                        Binding="{Binding Quantity}"
                                        Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"              Value="8,0"/>
                                <Setter Property="VerticalAlignment"    Value="Center"/>
                                <Setter Property="HorizontalAlignment"  Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- キャスト名 -->
                    <DataGridTextColumn Header="キャスト名"
                                        Binding="{Binding CastName}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding"           Value="8,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- ステータス（フィルタ▼付き） -->
                    <DataGridTemplateColumn Width="110">
                        <DataGridTemplateColumn.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ステータス"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ▼"
                                           Foreground="#FF4B7BBE"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}"
                                           Padding="8,0"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- 行ごとの▼ボタン -->
                    <DataGridTemplateColumn Width="44"
                                            Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="StatusChangeButton"
                                        Content="▼"
                                        Width="32"
                                        Height="26"
                                        FontSize="12"
                                        Margin="4,0"
                                        Background="#FF5CB85C"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF6FCF6F"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Opacity" Value="0.75"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- ─── 反映ボタン ────────────────────────── -->
        <Grid Grid.Row="1">
            <Button x:Name="ReflectButton"
                    Content="反映"
                    Width="80"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,20,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{StaticResource AttendStartBrush}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2"
                                                  BlurRadius="4"
                                                  Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AttendStartHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

    </Grid>

</UserControl>
