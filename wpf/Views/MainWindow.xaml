<Window x:Class="wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:wpf.Views.Pages"
        Title="KPosSystem"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- ヘッダー -->
            <RowDefinition Height="80"/>
            <!-- コンテンツ -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             ヘッダー（菱形パターン背景）
        ═══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderPatternBrush}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- タイトル -->
                    <ColumnDefinition Width="*"/>
                    <!-- ナビゲーションボタン -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- タイトル -->
                <TextBlock Grid.Column="0"
                           Text="KPos System"
                           Foreground="#AAFFFFFF"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <!-- ナビゲーションボタン（設定・テーブル・勤怠） -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0">

                    <Button x:Name="NavSettingButton"
                            Content="設定"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonSettingBrush}"
                            Margin="0,0,8,0"
                            Click="NavSetting_Click"/>

                    <Button x:Name="NavTableButton"
                            Content="テーブル"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonTableBrush}"
                            Margin="0,0,8,0"
                            Click="NavTable_Click"/>

                    <Button x:Name="NavAttendanceButton"
                            Content="勤怠"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonAttendanceBrush}"
                            Click="NavAttendance_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ═══════════════════════════════════════
             コンテンツエリア（ページ切替）
        ═══════════════════════════════════════ -->
        <ContentControl Grid.Row="1"
                        x:Name="MainContent"/>

    </Grid>

</Window>
