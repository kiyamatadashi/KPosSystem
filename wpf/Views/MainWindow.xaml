<Window x:Class="wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POS Screen"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid Margin="16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,12">

                <TextBox x:Name="ProductNameTextBox"
                         Width="220"
                         Height="36"
                         Margin="0,0,8,0"/>

                <TextBox x:Name="QuantityTextBox"
                         Width="80"
                         Height="36"
                         Margin="0,0,8,0"
                         Text="1"/>

                <Button Content="注文作成"
                        Width="120"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="CreateOrder_Click"/>

                <Button Content="再読込"
                        Width="120"
                        Height="36"
                        Click="ReloadOrders_Click"/>

            </StackPanel>

            <DataGrid Grid.Row="1"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding FilteredOrders}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="テーブル"
                                        Binding="{Binding SetNumber}"
                                        Width="180"/>

                    <DataGridTextColumn Header="商品名"
                                        Binding="{Binding ProductName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="数量"
                                        Binding="{Binding Quantity}"
                                        Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

    </Grid>
</Window>