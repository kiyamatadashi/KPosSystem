<UserControl x:Class="registerSystem.Views.Pages.TablePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- テーブル画面：空席ボタン＋使用中ボタンをWrapPanelで並べる
         設計書: ボタン左上から適度な余白でグリッド配置 -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <ScrollViewer Margin="14,14,14,14"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <WrapPanel x:Name="TableButtonPanel"
                       Orientation="Horizontal">

                <!-- 空席ボタン サンプル -->
                <Button Style="{StaticResource TableEmptyButtonStyle}"
                        Margin="10">
                    <TextBlock Text="空席"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- 使用中テーブルボタン サンプル -->
                <Button Style="{StaticResource TableUsedButtonStyle}"
                        Margin="10">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="8,6">
                        <TextBlock Text="テーブル名"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="客数"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <TextBlock Text="残り時間"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

            </WrapPanel>

        </ScrollViewer>

    </Grid>

</UserControl>
