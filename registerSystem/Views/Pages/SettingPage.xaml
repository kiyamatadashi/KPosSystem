<UserControl x:Class="registerSystem.Views.Pages.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 設定画面：左サイドメニュー＋右コンテンツエリア
         設計書: サイドボタンは左端から適度な余白、ボタン間に余白あり
                コンテンツは白い矩形で残り幅を占有 -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.ColumnDefinitions>
            <!-- サイドメニュー：ボタン80px + 左右余白 = 110px -->
            <ColumnDefinition Width="110"/>
            <!-- コンテンツエリア -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── サイドメニュー ─── -->
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Top"
                    Margin="14,16,0,16">

            <Button x:Name="SideButton1"
                    Content="釦１"
                    Style="{StaticResource SideButtonStyle}"/>

            <Button x:Name="SideButton2"
                    Content="釦２"
                    Style="{StaticResource SideButtonStyle}"/>

            <Button x:Name="SideButton3"
                    Content="釦３"
                    Style="{StaticResource SideButtonStyle}"/>

        </StackPanel>

        <!-- ─── コンテンツエリア ─── -->
        <Border Grid.Column="1"
                Background="White"
                Margin="6,16,16,16"
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15"/>
            </Border.Effect>
            <ContentControl x:Name="ContentArea"/>
        </Border>

    </Grid>

</UserControl>
