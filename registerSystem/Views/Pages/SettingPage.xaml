<UserControl x:Class="registerSystem.Views.Pages.SettingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 設定画面：左サイドメニュー＋右コンテンツエリア -->
    <Grid Background="{StaticResource ContentTextureBrush}">

        <Grid.ColumnDefinitions>
            <!-- サイドメニュー：ボタン80px + 左右余白 = 110px -->
            <ColumnDefinition Width="110"/>
            <!-- コンテンツエリア -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── サイドメニュー ─── -->
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Top"
                    Margin="14,16,0,16">

            <Button x:Name="SideButton1"
                    Content="料金"
                    Style="{StaticResource SideButtonStyle}"
                    Click="SideButton1_Click"/>

            <Button x:Name="SideButton2"
                    Content="テーブル"
                    Style="{StaticResource SideButtonStyle}"
                    Click="SideButton2_Click"/>

            <Button x:Name="SideButton3"
                    Content="入出金"
                    Style="{StaticResource SideButtonStyle}"
                    Click="SideButton3_Click"/>

            <Button x:Name="SideButtonMenu"
                    Content="メニュー"
                    Style="{StaticResource SideButtonStyle}"
                    Click="SideButtonMenu_Click"/>

            <Button x:Name="SideButtonQr"
                    Content="QR"
                    Style="{StaticResource SideButtonStyle}"
                    Click="SideButtonQr_Click"/>

        </StackPanel>

        <!-- ─── コンテンツエリア ─── -->
        <Border Grid.Column="1"
                Background="White"
                Margin="6,16,16,16"
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Opacity="0.15"/>
            </Border.Effect>

            <!-- 通常コンテンツ（料金・テーブル・入出金）-->
            <Grid>
                <ContentControl x:Name="ContentArea"
                                Visibility="Visible"/>

                <!-- ─── メニュー画面（ProductMaster編集）─── -->
                <Grid x:Name="MenuContent"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <!-- DataGrid: 残余領域すべて -->
                        <RowDefinition Height="*"/>
                        <!-- ボタン行: ボタン高さのみ -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DataGrid
                         ・SelectionUnit=Cell で1クリック編集の前提を作る
                         ・PreviewMouseLeftButtonDown でシングルクリック編集を有効化
                    -->
                    <DataGrid x:Name="ProductGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              FontSize="{DynamicResource FontSizeMd}"
                              RowHeight="{DynamicResource RowHeight}"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              Margin="0"
                              PreviewMouseLeftButtonDown="ProductGrid_PreviewMouseLeftButtonDown">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontSize"   Value="{DynamicResource FontSizeMd}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding"    Value="6,4"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="FontSize" Value="{DynamicResource FontSizeMd}"/>
                                <Setter Property="Padding"  Value="4,2"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <!-- カテゴリ（文字列入力） -->
                            <DataGridTemplateColumn Header="カテゴリ" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Category}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="{DynamicResource FontSizeMd}"
                                                 BorderThickness="0"
                                                 Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 商品Gr（SideMenu・文字列入力） -->
                            <DataGridTemplateColumn Header="商品Gr" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SideMenu}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding SideMenu, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="{DynamicResource FontSizeMd}"
                                                 BorderThickness="0"
                                                 Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 商品名（文字列入力） -->
                            <DataGridTemplateColumn Header="商品名" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductName}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="{DynamicResource FontSizeMd}"
                                                 BorderThickness="0"
                                                 Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 単価（数値入力） -->
                            <DataGridTemplateColumn Header="単価" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Amount}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="{DynamicResource FontSizeMd}"
                                                 TextAlignment="Right"
                                                 BorderThickness="0"
                                                 Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- バック金額（数値入力） -->
                            <DataGridTemplateColumn Header="バック金額" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BackAmount}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding BackAmount, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="{DynamicResource FontSizeMd}"
                                                 TextAlignment="Right"
                                                 BorderThickness="0"
                                                 Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- バック単位（円 or ％ の選択）
                                 SelectedItem に string を直接バインドするため
                                 ItemsSource を x:Array で定義し SelectedItem を使用する。
                                 ComboBoxItem を使うと選択後に ComboBoxItem オブジェクトが
                                 バインディング先に入り文字化けするため、この方式にする。 -->
                            <DataGridTemplateColumn Header="バック単位" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BackUnit}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding BackUnit, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  FontSize="{DynamicResource FontSizeMd}"
                                                  BorderThickness="0">
                                            <ComboBox.ItemsSource>
                                                <x:Array Type="{x:Type sys:String}"
                                                         xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>円</sys:String>
                                                    <sys:String>％</sys:String>
                                                </x:Array>
                                            </ComboBox.ItemsSource>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 割物選択（可 or 否）: 同様に SelectedItem + ItemsSource 方式 -->
                            <DataGridTemplateColumn Header="割物選択" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MixSelectableDisplay}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding MixSelectableDisplay, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  FontSize="{DynamicResource FontSizeMd}"
                                                  BorderThickness="0">
                                            <ComboBox.ItemsSource>
                                                <x:Array Type="{x:Type sys:String}"
                                                         xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>可</sys:String>
                                                    <sys:String>否</sys:String>
                                                </x:Array>
                                            </ComboBox.ItemsSource>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- キャスト選択（可 or 否）: 同様に SelectedItem + ItemsSource 方式 -->
                            <DataGridTemplateColumn Header="キャスト選択" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CastSelectableDisplay}"
                                                   FontSize="{DynamicResource FontSizeMd}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding CastSelectableDisplay, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  FontSize="{DynamicResource FontSizeMd}"
                                                  BorderThickness="0">
                                            <ComboBox.ItemsSource>
                                                <x:Array Type="{x:Type sys:String}"
                                                         xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <sys:String>可</sys:String>
                                                    <sys:String>否</sys:String>
                                                </x:Array>
                                            </ComboBox.ItemsSource>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- 削除（チェックボックス・デフォルトOFF） -->
                            <DataGridTemplateColumn Header="削除" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDeleted, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  Focusable="False"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsDeleted, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 下部エリア：追加・反映ボタン -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="8,6,8,8">

                        <!-- 追加ボタン -->
                        <Button x:Name="AddRowButton"
                                Content="追加"
                                Width="100"
                                Height="44"
                                FontSize="{DynamicResource FontSizeLg}"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="{StaticResource SideButtonBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,8,0"
                                Click="AddRowButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SideButtonHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.75"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 反映ボタン -->
                        <Button x:Name="ApplyButton"
                                Content="反映"
                                Width="100"
                                Height="44"
                                FontSize="{DynamicResource FontSizeLg}"
                                FontWeight="Bold"
                                Foreground="White"
                                Background="{StaticResource NavButtonSettingBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ApplyButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.3"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Opacity" Value="0.70"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                </Grid>

                <!-- ─── QRコード画面 ─── -->
                <Grid x:Name="QrContent"
                      Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <TextBlock Text="オーダーシステム QRコード"
                                   FontSize="{DynamicResource FontSizeLg}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <Border BorderBrush="#FFCCCCCC"
                                BorderThickness="1"
                                Padding="16"
                                Background="White">
                            <Image x:Name="QrImage"
                                   Width="280"
                                   Height="280"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>

                        <TextBlock x:Name="QrUrlText"
                                   FontSize="{DynamicResource FontSizeMd}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>

                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

    </Grid>

</UserControl>
