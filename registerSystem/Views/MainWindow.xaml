<Window x:Class="registerSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPosSystem - レジシステム"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー：ボタンが上下に切れないよう Padding で余白確保 -->
        <Border Grid.Row="0"
                MinHeight="{DynamicResource HeaderHeight}"
                Padding="0,10,0,10"
                Background="{StaticResource HeaderPatternBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="KPos System"
                           Foreground="#AAFFFFFF"
                           FontSize="{DynamicResource FontSizeHeader}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">

                    <Button x:Name="NavSettingButton"
                            Content="設定"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonSettingBrush}"
                            Margin="0,0,8,0"
                            Click="NavSetting_Click"/>

                    <Button x:Name="NavTableButton"
                            Content="テーブル"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonTableBrush}"
                            Margin="0,0,8,0"
                            Click="NavTable_Click"/>

                    <Button x:Name="NavAttendanceButton"
                            Content="勤怠"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonAttendanceBrush}"
                            Margin="0,0,16,0"
                            Click="NavAttendance_Click"/>

                    <!-- とじるボタン -->
                    <Button x:Name="CloseButton"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock TextAlignment="Center"
                                   FontSize="{DynamicResource FontSizeSm}"
                                   FontWeight="Bold"
                                   LineHeight="16">
                            <Run Text="とじる"/>
                        </TextBlock>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1"
                        x:Name="MainContent"/>

    </Grid>

</Window>
