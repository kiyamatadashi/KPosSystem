<Window x:Class="registerSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPosSystem - レジシステム"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <!-- ヘッダー：設計書に合わせて60px -->
            <RowDefinition Height="60"/>
            <!-- コンテンツ -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             ヘッダー（菱形パターン）
        ═══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderPatternBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- タイトル -->
                <TextBlock Grid.Column="0"
                           Text="KPos System"
                           Foreground="#AAFFFFFF"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <!-- ナビゲーションボタン（設定・テーブル・勤怠）
                     設計書: ヘッダー右端に3ボタン・適度な間隔 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">

                    <Button x:Name="NavSettingButton"
                            Content="設定"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonSettingBrush}"
                            Margin="0,0,8,0"
                            Click="NavSetting_Click"/>

                    <Button x:Name="NavTableButton"
                            Content="テーブル"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonTableBrush}"
                            Margin="0,0,8,0"
                            Click="NavTable_Click"/>

                    <Button x:Name="NavAttendanceButton"
                            Content="勤怠"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource NavButtonAttendanceBrush}"
                            Click="NavAttendance_Click"/>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             コンテンツエリア（ページ切替）
        ═══════════════════════════════════════ -->
        <ContentControl Grid.Row="1"
                        x:Name="MainContent"/>

    </Grid>

</Window>
