@page "/"
@inject OrderApiService OrderApi

<div class="order-page">

    <!-- ヘッダー -->
    <div class="order-header">
        <div class="header-left">
            <!-- キャストボタン（オレンジ丸） -->
            <button class="btn-header btn-cast" @onclick="OnCastClick">キャスト</button>
            <!-- 変更ボタン（緑丸） -->
            <button class="btn-header btn-change" @onclick="OnChangeClick">変更</button>
        </div>
        <div class="header-right">
            <!-- 履歴ボタン（青丸） -->
            <button class="btn-header btn-history" @onclick="OnHistoryClick">履歴</button>
        </div>
    </div>

    <!-- カテゴリ選択エリア -->
    <div class="order-content">

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-banner">⚠ @_errorMessage</div>
        }

        <!-- ドリンクカテゴリ（青角丸ボタン） -->
        <div class="btn-group">
            <button class="btn-category btn-drink" @onclick='() => OnCategoryClick("シャンパン")'>シャンパン</button>
            <button class="btn-category btn-drink" @onclick='() => OnCategoryClick("ボトル")'>ボトル</button>
            <button class="btn-category btn-drink" @onclick='() => OnCategoryClick("飲み放題")'>飲み放題</button>
            <button class="btn-category btn-drink" @onclick='() => OnCategoryClick("ショット")'>ショット</button>
        </div>

        <!-- キャスト系カテゴリ（オレンジ角丸ボタン） -->
        <div class="btn-group">
            <button class="btn-category btn-cast-item" @onclick='() => OnCategoryClick("キャスト")'>キャスト</button>
            <button class="btn-category btn-cast-item" @onclick='() => OnCategoryClick("チェキ")'>チェキ</button>
        </div>

    </div>

</div>

@code {
    private bool _isLoading = false;
    private string _errorMessage = string.Empty;

    private void OnCastClick()
    {
        // キャスト選択：別途指示
    }

    private void OnChangeClick()
    {
        // 変更：別途指示
    }

    private void OnHistoryClick()
    {
        // 履歴：別途指示
    }

    private void OnCategoryClick(string category)
    {
        // カテゴリ選択：別途指示
    }
}
