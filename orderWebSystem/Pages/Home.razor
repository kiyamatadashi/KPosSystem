@page "/"
@inject OrderApiService OrderApi

<div class="order-page">

    <!-- ヘッダー -->
    <div class="order-header">
        <div class="header-left">
            <!-- キャストボタン（オレンジ丸） -->
            <button class="btn-header btn-cast" @onclick="OnCastClick">キャスト</button>
            <!-- 変更ボタン（緑丸） -->
            <button class="btn-header btn-change" @onclick="OnChangeClick">変更</button>
        </div>
        <div class="header-right">
            <!-- 履歴ボタン（青丸） -->
            <button class="btn-header btn-history" @onclick="OnHistoryClick">履歴</button>
        </div>
    </div>

    <!-- カテゴリ選択エリア -->
    <div class="order-content">

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-banner">⚠ @_errorMessage</div>
        }

        @if (_isLoading)
        {
            <div>読み込み中...</div>
        }
        else
        {
            <!-- カテゴリボタン（ProductMasterのCategoryをユニーク化して動的表示） -->
            <div class="btn-group">
                @foreach (var category in _categories)
                {
                    <button class="btn-category btn-drink" @onclick="() => OnCategoryClick(category)">@category</button>
                }
            </div>
        }

    </div>

</div>

@code {
    private bool _isLoading = false;
    private string _errorMessage = string.Empty;
    private List<string> _categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
    }

    private async Task LoadCategoriesAsync()
    {
        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var products = await OrderApi.GetProductMastersAsync();
            _categories = products
                .Select(p => p.Category)
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"商品マスタの取得に失敗しました。{ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnCastClick()
    {
        // キャスト選択：別途指示
    }

    private void OnChangeClick()
    {
        // 変更：別途指示
    }

    private void OnHistoryClick()
    {
        // 履歴：別途指示
    }

    private void OnCategoryClick(string category)
    {
        // カテゴリ選択：別途指示
    }
}
